# Python
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
.venv/

# Large raw datasets — never committed (fetch per spec_04)
datasets/

# TensorRT engines — hardware-specific (sm_120), rebuilt per target; never ship
*.plan
*.engine

# ISL artefacts are PRODUCED BY PARTICIPANTS during the lab — keep them out so
# the repo ships ASL pre-trained only. (languages/isl/{config.yaml,references/}
# ARE tracked; the trained model + landmarks are the lab deliverable.)
languages/isl/landmarks.csv
languages/isl/model.onnx
checkpoints/isl/

# We DO ship ASL pre-trained: languages/asl/{model.onnx,landmarks.csv},
# checkpoints/asl/, and k8s/chart/files/asl/model.onnx are committed.

# OS
.DS_Store

# Raw debugging artefacts (HAR captures, kubectl dumps) — keep reports, not these
Logs/*.har
Logs/*.txt
